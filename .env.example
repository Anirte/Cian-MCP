AUTH0_DOMAIN=your-tenant.region.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_AUDIENCE=your-auth0-api-audience
BASE_URL=https://your-render-service.onrender.com
JWT_SIGNING_KEY=replace-with-a-long-random-secret

# Comma-separated MCP client redirect URI patterns.
# Use "*" or "all" only if you intentionally want to allow every MCP client redirect URI.
ALLOWED_CLIENT_REDIRECT_URIS=https://claude.ai/api/mcp/auth_callback,https://claude.com/api/mcp/auth_callback,https://chatgpt.com/*,https://chat.openai.com/*,http://localhost:*,http://127.0.0.1:*,cursor://anysphere.cursor-mcp/oauth/callback
